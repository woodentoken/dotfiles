# _________________________________________________________________________________
#

# Shell behavior: options, history, and keybindings.

# -----------------------------------------------------------------------------
# PROMPT INIT
# -----------------------------------------------------------------------------
autoload -Uz promptinit
promptinit

# -----------------------------------------------------------------------------
# HISTORY
# -----------------------------------------------------------------------------
setopt histignorealldups sharehistory

HISTSIZE=5000
SAVEHIST=5000
HISTFILE=~/.zsh_history

# -----------------------------------------------------------------------------
# DIRECTORY STACK
# -----------------------------------------------------------------------------
setopt CDABLE_VARS
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHDMINUS

# -----------------------------------------------------------------------------
# KEYBINDINGS
# -----------------------------------------------------------------------------
# Use emacs keybindings even if EDITOR is set to vi
bindkey -e

bindkey "^U" clear-screen
bindkey "^L" kill-whole-line

# Ctrl-Z: bidirectional (foreground if no buffer, background otherwise)
fancy-ctrl-z () {
  if [[ $#BUFFER -eq 0 ]]; then
    BUFFER="fg"
    zle accept-line -w
  else
    zle push-input -w
    zle clear-screen -w
  fi
}
zle -N fancy-ctrl-z
bindkey '^Z' fancy-ctrl-z

# -----------------------------------------------------------------------------
# STARTUP
# -----------------------------------------------------------------------------
# Launch bspwm on login (X11)
if [ -z "${DISPLAY}" ] && [ "${XDG_VTNR}" -eq 1 ]; then
   exec startx
fi
